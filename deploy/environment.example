APP_ENV=prod
TZ=Asia/Shanghai

MYSQL_HOST=middleware
MYSQL_PORT=3306
MYSQL_USER=agentscope
MYSQL_PASSWORD=agentscope_pass
MYSQL_SOURCE_DB=agentscope_source
MYSQL_ANALYTICS_DB=agentscope_analytics
MYSQL_ANALYTICS_ENABLED=1

REDIS_HOST=middleware
REDIS_PORT=6379
REDIS_DB=0

KAFKA_BOOTSTRAP_SERVERS=middleware:9092
KAFKA_TOPIC=agent-events

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
VITE_API_BASE_URL=/api/v1

# Optional LLM report provider.
# When unset, backend falls back to deterministic rule-based Markdown.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL_NAME=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=300
OPENAI_MAX_RETRIES=0

