# Shared
APP_ENV=dev
TZ=Asia/Shanghai
DATA_MODE=demo # Options: demo (allows mock fallback), strict (no mock fallback)

# Middleware node in the five-node design
MYSQL_HOST=middleware
MYSQL_PORT=3306
MYSQL_USER=agentscope
MYSQL_PASSWORD=agentscope_pass
MYSQL_SOURCE_DB=agentscope_source
MYSQL_ANALYTICS_DB=agentscope_analytics
MYSQL_JDBC_URL=jdbc:mysql://middleware:3306/agentscope_analytics?useSSL=false&useUnicode=true&characterEncoding=utf8

REDIS_HOST=middleware
REDIS_PORT=6379
REDIS_DB=0

KAFKA_BOOTSTRAP_SERVERS=middleware:9092
KAFKA_TOPIC=agent-events

# Cluster Environments
SSH_USER=root
SSH_HOST=master
SSH_OPTS=-o StrictHostKeyChecking=no
PROJECT_HOME=/root/projects/agentscope
JAVA_HOME=/usr/local/jdk1.8.0_171
HADOOP_HOME=/usr/local/hadoop-2.7.6
HADOOP_CONF_DIR=/usr/local/hadoop-2.7.6/etc/hadoop
YARN_CONF_DIR=/usr/local/hadoop-2.7.6/etc/hadoop
SPARK_HOME=/usr/local/spark
SPARK_MASTER=yarn
SPARK_DEPLOY_MODE=client
# Optional Standalone fallback:
# SPARK_MASTER=spark://master:7077
YARN_HOST=master
YARN_PORT=8088

# HDFS paths
HDFS_RAW_BASE=/agentscope/raw/agent_events
HDFS_CLEAN_BASE=/agentscope/clean/agent_events
HDFS_METRIC_BASE=/agentscope/metric

# API / frontend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_PUBLIC_HOST=127.0.0.1
VITE_API_BASE_URL=/api/v1
VITE_DEV_API_TARGET=http://127.0.0.1:8000
VITE_API_TIMEOUT=60000
VITE_REPORT_TIMEOUT=190000

# Optional LLM report provider.
# When unset, backend falls back to deterministic rule-based Markdown.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL_NAME=deepseek-ai/DeepSeek-V4-Flash
OPENAI_TIMEOUT_SECONDS=180
OPENAI_MAX_RETRIES=0

